// This is your Prisma schema file (Updated for approval)
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  ADMIN // Quản trị viên
  AM // Account Manager
  CV // Chuyên viên
  USER // Nhân viên (Legacy)
}

enum LogStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PhanLoaiKH {
  CHINH_PHU // Sở, Ban, Ngành
  DOANH_NGHIEP // Doanh nghiệp tư nhân
  CONG_AN // Công an (B2A)
}

enum TrangThaiDuAn {
  MOI // Mới
  DANG_LAM_VIEC // Đang làm việc
  DA_DEMO // Đã demo
  DA_GUI_BAO_GIA // Đã gửi báo giá
  DA_KY_HOP_DONG // Đã ký hợp đồng
  THAT_BAI // Thất bại
}

enum LinhVuc {
  CHINH_PHU // Chính phủ/ Sở ban ngành
  DOANH_NGHIEP // Doanh nghiệp
  CONG_AN // Công an
}

enum LoaiTinNhan {
  TEXT
  SYSTEM
}

// ============================================
// MODELS
// ============================================

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  emailVerified  Boolean   @default(false)
  image          String?
  hashedPassword String?
  role           UserRole  @default(USER)
  diaBan         String?   @default("Chưa phân công")
  avatarUrl      String?
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  banned         Boolean   @default(false)
  banReason      String?
  banExpires     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  duAnAM        DuAn[]           @relation("AMRelation")
  duAnAMHoTro   DuAn[]           @relation("AMHoTroRelation")
  duAnCV        DuAn[]           @relation("CVRelation")
  duAnCVHoTro1  DuAn[]           @relation("CVHoTro1Relation")
  duAnCVHoTro2  DuAn[]           @relation("CVHoTro2Relation")
  nhatKy        NhatKyCongViec[]
  binhLuan      BinhLuan[]
  tinNhan       TinNhan[]
  sessions      Session[]
  accounts      Account[]
  notifications Notification[]

  @@index([email])
  @@index([role])
  @@index([diaBan])
  @@index([updatedAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id           String    @id @default(cuid())
  userId       String
  accountId    String
  providerId   String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  password     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model KhachHang {
  id          Int        @id @default(autoincrement())
  ten         String
  phanLoai    PhanLoaiKH
  diaChi      String?
  soDienThoai String?
  email       String?

  // Thông tin liên hệ & Đầu mối
  dauMoiTiepCan      String? // Đầu mối tiếp cận
  soDienThoaiDauMoi  String? // Số điện thoại đầu mối
  ngaySinhDauMoi     DateTime? // Ngày sinh nhật đầu mối
  lanhDaoDonVi       String? // Lãnh đạo đơn vị
  soDienThoaiLanhDao String? // Số điện thoại Lãnh đạo
  ngaySinhLanhDao    DateTime? // Ngày sinh nhật Lãnh đạo

  // Ngày kỷ niệm
  ngayThanhLap DateTime? // Ngày thành lập
  ngayKyNiem   DateTime? // Ngày kỷ niệm
  ghiChu       String? // Ghi chú thêm

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  duAns DuAn[]

  @@index([phanLoai])
  @@index([ten])
  @@index([updatedAt])
}

model SanPham {
  id         Int      @id @default(autoincrement())
  nhom       String
  tenChiTiet String
  moTa       String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  duAns DuAn[]

  @@index([nhom])
  @@index([nhom, tenChiTiet])
}

model DuAn {
  id                  Int           @id @default(autoincrement())
  customerId          Int
  productId           Int
  amId                String?
  amHoTroId           String?
  chuyenVienId        String?
  cvHoTro1Id          String?
  cvHoTro2Id          String?
  tenDuAn             String
  linhVuc             LinhVuc       @default(CHINH_PHU)
  tongDoanhThuDuKien  Float         @default(0)
  doanhThuTheoThang   Float?        @default(0)
  maHopDong           String?
  ngayBatDau          DateTime
  ngayKetThuc         DateTime?
  isTrongDiem         Boolean       @default(false)
  isKyVong            Boolean       @default(false)
  hienTaiBuoc         String? // Bước hiện tại của dự án
  isPendingDelete     Boolean       @default(false)
  deleteRequestedAt   DateTime?
  tuan                Int
  thang               Int
  quy                 Int
  nam                 Int
  ngayChamsocCuoiCung DateTime?
  trangThaiHienTai    TrangThaiDuAn @default(MOI)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relations
  khachHang  KhachHang @relation(fields: [customerId], references: [id])
  sanPham    SanPham   @relation(fields: [productId], references: [id])
  am         User?     @relation("AMRelation", fields: [amId], references: [id], onDelete: SetNull)
  amHoTro    User?     @relation("AMHoTroRelation", fields: [amHoTroId], references: [id], onDelete: SetNull)
  chuyenVien User?     @relation("CVRelation", fields: [chuyenVienId], references: [id], onDelete: SetNull)
  cvHoTro1   User?     @relation("CVHoTro1Relation", fields: [cvHoTro1Id], references: [id], onDelete: SetNull)
  cvHoTro2   User?     @relation("CVHoTro2Relation", fields: [cvHoTro2Id], references: [id], onDelete: SetNull)

  nhatKy        NhatKyCongViec[]
  binhLuan      BinhLuan[]
  tinNhan       TinNhan[]
  notifications Notification[]

  @@index([customerId])
  @@index([productId])
  @@index([amId])
  @@index([chuyenVienId])
  @@index([trangThaiHienTai])
  @@index([linhVuc])
  @@index([nam, quy, thang])
  @@index([ngayChamsocCuoiCung])
  @@index([updatedAt])
  @@index([tenDuAn])
  @@index([isPendingDelete])
}

model NhatKyCongViec {
  id             Int           @id @default(autoincrement())
  projectId      Int
  userId         String
  ngayGio        DateTime      @default(now())
  trangThaiMoi   TrangThaiDuAn
  noiDungChiTiet String
  buoc           String? // Bước quy trình (nếu có)
  status         LogStatus     @default(APPROVED)
  createdAt      DateTime      @default(now())

  duAn DuAn @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  files FileDinhKem[]

  @@index([projectId])
  @@index([userId])
  @@index([projectId, ngayGio]) // Tối ưu cho nhatKy: { orderBy: { ngayGio: 'desc' } }
}

model BinhLuan {
  id        Int      @id @default(autoincrement())
  projectId Int
  userId    String
  content   String
  parentId  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  duAn    DuAn       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  BinhLuan?  @relation("CommentThread", fields: [parentId], references: [id])
  replies BinhLuan[] @relation("CommentThread")

  @@index([projectId])
  @@index([userId])
  @@index([parentId])
  @@index([projectId, createdAt]) // Tối ưu cho binhLuan: { orderBy: { createdAt: 'desc' } }
}

model TinNhan {
  id        Int         @id @default(autoincrement())
  projectId Int
  userId    String
  content   String
  type      LoaiTinNhan @default(TEXT)
  isEdited  Boolean     @default(false)
  isDeleted Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  duAn DuAn @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([userId])
}

model ChiTieuKpi {
  id           Int      @id @default(autoincrement())
  nam          Int
  thang        Int
  anNinhMang   Float    @default(0)
  giaiPhapCntt Float    @default(0)
  duAnCds      Float    @default(0)
  cnsAnNinh    Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([nam, thang])
  @@index([nam])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    String
  title     String
  content   String
  isRead    Boolean  @default(false)
  type      String // "APPROVAL_REQUEST", "APPROVAL_RESULT"
  relatedId String? // Nhật ký ID (có thể dùng thay/cùng projectId)
  projectId Int?
  createdAt DateTime @default(now())

  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  project DuAn? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
}
model FileDinhKem {
  id        Int      @id @default(autoincrement())
  logId     Int
  name      String
  url       String
  type      String
  size      Int
  createdAt DateTime @default(now())

  log       NhatKyCongViec @relation(fields: [logId], references: [id], onDelete: Cascade)
  
  @@index([logId])
}

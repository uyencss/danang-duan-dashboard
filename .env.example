# Database (PostgreSQL via Tailscale)
# Format: postgresql://USER:PASSWORD@TAILSCALE_IP:5432/DB_NAME
DATABASE_URL="postgresql://postgres:your-password-here@100.x.y.z:5432/your-db-name"


# Authentication & App Config (Better Auth)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
BETTER_AUTH_SECRET="generate-a-random-secret-here"
BETTER_AUTH_URL="http://localhost:3000"

# Realtime & Network Providers
ABLY_API_KEY="your-ably-secret-key-here"
NEXT_PUBLIC_ABLY_KEY="your-ably-public-key-here"

# Deployment & Tunneling (Usually only needed in remote env)
CLOUDFLARE_TUNNEL_TOKEN=""
TAILSCALE_AUTHKEY=""

# Email/SMTP Configuration (For Notifications/Auth)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-app-password-here"
SMTP_FROM="noreply@example.com"

# SSH Configuration (Usually only needed in GitHub Actions)
SSH_HOST=""
SSH_USER=""
SSH_PRIVATE_KEY=""

# Redis Cache (Docker: redis://redis:6379, Local: redis://localhost:6379)
REDIS_URL=""

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
LOG_ROTATION_INTERVAL=1M
LOG_MAX_FILES=12
LOG_MAX_SIZE=100M

# File Upload
UPLOAD_DIR=./uploads              
UPLOAD_MAX_SIZE=20971520           # 20MB
IMAGE_MAX_KB=500                   # Max KB after resize

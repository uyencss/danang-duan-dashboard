# Database & Turso
DATABASE_URL="file:./data/local-replica.db-info"
TURSO_DATABASE_URL="libsql://your-database-id.turso.io"
TURSO_AUTH_TOKEN="your-turso-token-here"
TURSO_SYNC_PERIOD="60"
LOCAL_REPLICA_PATH="file:./data/local-replica.db-info"
LOCAL_DATABASE_URL="file:./data/local-replica.db-info"

# Authentication & App Config (Better Auth)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
BETTER_AUTH_SECRET="generate-a-random-secret-here"
BETTER_AUTH_URL="http://localhost:3000"

# Realtime & Network Providers
ABLY_API_KEY="your-ably-secret-key-here"
NEXT_PUBLIC_ABLY_KEY="your-ably-public-key-here"

# Deployment & Tunneling (Usually only needed in remote env)
CLOUDFLARE_TUNNEL_TOKEN=""
TAILSCALE_AUTHKEY=""

# Email/SMTP Configuration (For Notifications/Auth)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-app-password-here"
SMTP_FROM="noreply@example.com"

# SSH Configuration (Usually only needed in GitHub Actions)
SSH_HOST=""
SSH_USER=""
SSH_PRIVATE_KEY=""
# Logging
LOG_LEVEL=info
LOG_DIR=./logs
LOG_ROTATION_INTERVAL=1M
LOG_MAX_FILES=12
LOG_MAX_SIZE=100M

# File Upload
UPLOAD_DIR=./uploads              
UPLOAD_MAX_SIZE=20971520           # 20MB
IMAGE_MAX_KB=500                   # Max KB after resize

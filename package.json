{
  "name": "danang-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "db:sync": "tsx scripts/db-sync/sync-prod-to-dev.ts",
    "dev": "npm run db:sync && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "tsx prisma/seed.ts",
    "seed:reset": "SEED_RESET=true tsx prisma/seed.ts",
    "db:migrate:reset": "tsx scripts/db-management/migrate-reset-safe.ts",
    "db:migrate:reset:unsafe": "prisma migrate reset --force",
    "reset-passwords": "tsx --env-file=.env scripts/reset-all-passwords.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "npm run seed"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.6.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/pm": "^3.22.2",
    "@tiptap/react": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "@types/papaparse": "^5.5.2",
    "ably": "^2.21.0",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.5",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "recharts": "^3.8.1",
    "rotating-file-stream": "^3.2.9",
    "shadcn": "^4.1.2",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
